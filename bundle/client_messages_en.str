chat_command_invalid_format			^279* Неверный формат команды. Правильный формат:

chat_command_invalid_format_multi	^279* Неверный формат команды. Правильный формат один из:

chat_command_invalid_command		^279* Неверная команда. Введите {helpcommand} для получения списка команд.

chat_command_help_valid				^279* Доступные команды:

chat_command_help_whisper			^279*^707 /whisper <nickname> <message>^279  — Шёпот пользователю.

chat_command_help_reply				^279*^707 /reply <message>^279               — Ответ на последний шёпот.

chat_command_help_buddy				^279*^707 /friend <command> <arguments>^279   — Различные команды, связанные с друзьями.

chat_command_help_clan				^279*^707 /clan <command> <arguments>^279    — Различные команды, связанные с кланом.

chat_command_help_join				^279*^707 /join <channel> "password"^279     — Присоединяет к указанному каналу (опционально укажите пароль в кавычках).

chat_command_help_clear				^279*^707 /clear^279                         — Очищает буфер чата.

chat_command_help_invite			^279*^707 /invite <user>^279                 — Приглашает указанного пользователя в текущую игру.

chat_command_help_whois				^279*^707 /whois <user>^279                  — Получает информацию об указанном пользователе.

chat_command_help_stats				^279*^707 /stats <user> [pop]^279            — Получает статистику указанного пользователя (опционально добавьте «pop» для раскрытия).

chat_command_help_joingame			^279*^707 /joingame <type> <param>^279       — Присоединиться к игре.

chat_command_help_topic				^279*^707 /topic [topic]^279                 — Показывает или задаёт тему канала

chat_command_help_kick				^279*^707 /kick <user>^279                   — Исключает пользователя с канала (требуются права администратора).

chat_command_help_ban				^279*^707 /ban <user>^279                    — Банит пользователя на канале (требуются права администратора).

chat_command_help_unban				^279*^707 /unban <user>^279                  — Разбанивает пользователя на канале (требуются права администратора).

chat_command_help_silence			^279*^707 /silence <user> <duration>^279     — Заглушает пользователя на <duration> минут (требуются права администратора).

chat_command_help_promote			^279*^707 /promote <user>^279                — Повышает пользователя (требуются права администратора)

chat_command_help_demote			^279*^707 /demote <user>^279                 — Понижает пользователя (требуются права администратора)

chat_command_help_banlist			^279*^707 /banlist <command> <arguments>^279 — Команды управления бан-листом.

chat_command_help_ignore			^279*^707 /ignore <command> <arguments>^279  — Команды управления списком игнорирования.

chat_command_help_ignorechat		^279*^707 /ignorechat^279					 — Переключает игнорирование командного или общего чата.

chat_command_help_friendlychat		^279*^707 /friendlychat^279					 — Переключает игнорирование сообщений от игроков не из клана или друзей.

chat_command_help_notes				^279*^707 /notes <command> <arguments>^279   — Команды управления заметками.

chat_command_help_auth				^279*^707 /auth <command> <arguments>^279    — Управление списком авторизованных пользователей канала (требуются права администратора)

chat_command_help_password			^279*^707 /password <password>^279           — Устанавливает пароль канала (требуются права администратора)

chat_command_help_password_clear	^279*^707 /password^279						 — Очищает текущий пароль канала (требуются права администратора)

chat_command_help_roll				^279*^707 /roll <low> <high>^279			 — Выдаёт случайное число от min до max (от 1 до 32 767).

chat_command_help_emote				^279*^707 /emote <message>^279				 — Отправляет эмоцию от вашего имени.

chat_command_help_time				^279*^707 /time^279                          — Показывает ваше текущее системное время.

chat_command_help_ping				^279*^707 /ping^279 (in game only)           — Показывает ваш текущий пинг до игрового сервера.

chat_command_help_matchup			^279*^707 /matchup^279 (in game only)        — Показывает команду/имя/цвет/героя игроков в текущей игре.

chat_command_help_gameinfo			^279*^707 /gameinfo^279 (in game only)       — Показывает информацию о текущей игре.

chat_command_help_available			^279*^707 /available^279					 — Переключает статус чата на «Доступен».

chat_command_help_afk				^279*^707 /afk <afk message>^279			 — Переключает статус чата на «Вдали от клавиатуры», автоматически отвечает на шёпот указанным сообщением.

chat_command_help_dnd				^279*^707 /dnd <dnd message>^279			 — Переключает статус чата на «Не беспокоить», останавливает входящие шёпоты и автоматически отвечает на них указанным сообщением.

chat_command_help_weather			^279*^707 /weather^279 (in game only)        — Установить погодный эффект

chat_command_help_misc				^279* Введите любую команду без аргументов для информации о её использовании.





