State_Maliken_Ability2_Flame_name								Зачарованное пламя







State_Maliken_Ability2_Flame_description						







State_Maliken_Ability2_Flame_description2						







State_Maliken_Ability2_Flame_FRAME_effect						Наносит 15 маг. урона самому себе при атаке. Не приводит к падению здоровья ниже 15%.\n\n^yМодификации броска меча:^* Заставляет бросок меча наносить +{40,50,60,70} дополнительного маг. урона за каждую цель.







State_Maliken_Ability2_Flame_ATTACK_IMPACT_effect				















// State_Maliken_Ability2_Healing







State_Maliken_Ability2_Healing_name								Жизненная эссенция







State_Maliken_Ability2_Healing_description						







State_Maliken_Ability2_Healing_description2						







State_Maliken_Ability2_Healing_FRAME_effect						Исцеляет себя на здоровье, равное {10,20,30,40} + {2,3,4,5}% от вашего урона от атаки за атаку. \n\n^yМодификации броска меча:^* Заставляет бросок меча исцелять себя на {10,20,30,40} за каждую цель.















// Ability_Maliken3







Ability_Maliken3_name											Рвение Хеллборна







Ability_Maliken3_description									Maliken жертвует здоровьем для увеличения скор. атаки.







Ability_Maliken3_description2									







Ability_Maliken3_description_simple								Предоставляет ^o2 магической брони^*.\n\nДобавляет ^o{0.5,1,1.5,2} Скор. атаки^* и ^o{0.025,0.05,0.075,0.1} Магической брони^* за каждые ^o1% недостающего здоровья^*.







Ability_Maliken3_effect_header									







Ability_Maliken3_effect_header2									







Ability_Maliken3_tooltip_flavor									Разобьешь мне сердце - я сломаю тебя!







Ability_Maliken3_FRAME_effect									^oПолучайте {0.5,1,1.5,2} Скор. атаки и {0.025,0.05,0.075,0.1} Магическую броню^* за каждый недостающий ^o1% здоровья^*.







Ability_Maliken3_FRAME_effect:maliken_ability3_Armor			^oПолучайте {0.5,1,1.5,2} Скор. атаки и {0.025,0.05,0.075,0.1} Магическую броню^* за каждый недостающий ^o1% здоровья^*.















