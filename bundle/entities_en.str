// Ability_Magmus2







Ability_Magmus2_name											Паровая баня







Ability_Magmus2_description										Magmus поднимает каменные стены, наносящие урон и замедляющие врагов.







Ability_Magmus2_description2									







Ability_Magmus2_description_simple								^oКанал^*, чтобы нагреть область вокруг вас, выпуская пар, который наносит ^o{30,50,70,90} маг. урона в сек.у^* ближайшим врагам и делает вас ^oневидимым^* максимум на ^o60 сек.^*. ^oНевидимость^* сохраняется на ^o{0.6,0.9,1.2,1.5} сек.^* после ^oразрыва канала^*.







Ability_Magmus2_effect_header									Эффект(ы) паровой бани







Ability_Magmus2_effect_header2									







Ability_Magmus2_tooltip_flavor									Кто оставил сауну включенной?







Ability_Magmus2_CHANNEL_START_effect							







Ability_Magmus2_IMPACT_effect									Во время поддержания применяет к себе паровую баню и наносит ^o{30,50,70,90} маг. урона^* врагам в радиусе вокруг себя. Отключает снаряды при применении.\n\nПри разрыве поддержаниеа происходит ^o{0.6,0.9,1.2,1.5} секундная задержка^*, прежде чем скрытность будет снята.















