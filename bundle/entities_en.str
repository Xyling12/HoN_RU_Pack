// Hero_Cthulhuphant







Hero_Cthulhuphant_name											Ктулхуфант







Hero_Cthulhuphant_description									Затерянный на глубинах темнейшего моря, мертвый бегемот грезил кошмаром непостижимого зла. Пропитанный первобытными энергиями земли, его сон обрел реальность как живое предзнаменование безумия, выбравшееся со дна океана на сушу.







Hero_Cthulhuphant_role											Cthulhuphant - крепкий бойцы ближнего боя с огромной выживаемостью в начале игры. Когда он готов к командным боям, его способности опустошают врагов.























































// Ability_Dampeer1







Ability_Dampeer1_name											Терроризирование







Ability_Dampeer1_description									Дампир вселяет ужас в ближайших врагов, нанося урон и заставляя их бесцельно метаться.







Ability_Dampeer1_description_simple								Активируйте, чтобы нанести ^o{75,125,175,225} маг. урона^* и ^o1 сек.у страха^* врагам в области вокруг вас.\n\nУвеличьте урон на 35 и продолжительность страха на 0,25 сек. за каждую ^rEssence^*, которой обладает Дампир. Максимальная продолжительность страха 2 сек. с ^gПосох Мастера^*.







Ability_Dampeer1_description2									







Ability_Dampeer1_effect_header									Эффект(ы) страха







Ability_Dampeer1_effect_header2									







Ability_Dampeer1_tooltip_flavor									БУ!







Ability_Dampeer1_LEARN_effect									







Ability_Dampeer1_IMPACT_effect									Наносит ^o{75,125,175,225} магического урона^* и применяет ^oFear^* на ^o1 секунду^*.\n\nКаждая имеющаяся ^rЭссенция^* увеличивает урон на 35, а продолжительность страха - на 0,25 секунды. Максимальная продолжительность страха 2 секунды с ^gПосох Мастера^*.















// State_Dampeer_Ability1_Fear







State_Dampeer_Ability1_Fear_name								В ужасе







State_Dampeer_Ability1_Fear_description							Не трусь!







State_Dampeer_Ability1_Fear_FRAME_effect						Теряет контроль, мечется в страхе.















// Ability_Dampeer2







Ability_Dampeer2_name											Вампирский полет







Ability_Dampeer2_description									Дампир взлетает к цели, нанося урон и похищая жизнь у врагов на своем пути.







Ability_Dampeer2_description_simple								Нацельтесь на врага, чтобы полететь к нему. Каждый раз, когда Дампир проходит сквозь врага, он наносит ему ^o{50,90,130,170} маг. урона^* и ^oисцеляется на {12,18,24,30}^*.\n\nУвеличивает урон на 30 и исцеляет на 10 за каждую ^rEssence^*, которой обладает Дампир.







Ability_Dampeer2_description2									







Ability_Dampeer2_effect_header									







Ability_Dampeer2_effect_header2									







Ability_Dampeer2_tooltip_flavor									Как мышь из преисподней!







Ability_Dampeer2_IMPACT_effect									Летит к цели, нанося ^o{50,90,130,170} маг. урона^* и ^oисцеления на {12,18,24,30}^* здоровья за каждого врага, через которого вы пролетаете.\n\nКаждая ^rСущность^* увеличивает урон на 30 и исцеляет на 10.















// State_Dampeer_Ability2_Self







State_Dampeer_Ability2_Self_name								Вампирский полет















// Ability_Dampeer3







Ability_Dampeer3_name											Жажда крови







Ability_Dampeer3_description									Дампир и ближайшие союзники получают кражу жизни при атаках.







Ability_Dampeer3_description_simple								Пассивно дает ближайшим союзным юнитам ближнего боя ^o{15,20,25,30}% вампиризма^*. Союзники дальнего боя получают ^o{2.5,5,7.5,10}% вампиризма^*.\n\nПереключите, чтобы воздействовать только на ближайших союзных героев.\n\nПассивно получает 10 скор. атаки за каждую ^rEssence^*, которой обладает Дампир.







Ability_Dampeer3_description_simple:Dampeer_Aura_Heroes			Пассивно дает ближайшим союзникам ближнего боя ^o{15,20,25,30}% вампиризма^*. Герои дальнего боя получают ^o{2.5,5,7.5,10}% вампиризма^*.\n\nПереключить, чтобы воздействовать на всех ближайших союзных юнитов.\n\nПассивно получает 10 скор. атаки за каждую ^rEssence^*, которой обладает Дампир.







Ability_Dampeer3_description2									Дает союзникам ближнего боя {15,20,25,30}% вампиризм, а союзникам дальнего боя {2.5,5,7.5,10}% вампиризм.\n\nКаждая ^rEssence^* пассивно дает Dampeer 10 скор. атаки.







Ability_Dampeer3_description2:Dampeer_Aura_Heroes				Дает героям ближнего боя {15,20,25,30}% вампиризм, а героям дальнего боя {2.5,5,7.5,10}% вампиризм.\n\nКаждая ^rEssence^* пассивно дает Dampeer 10 скор. атаки.







Ability_Dampeer3_IMPACT_effect									Изменяет схему цели ауры на союзных героев.







Ability_Dampeer3_name:Dampeer_Aura_Heroes						Жажда крови (герои)







Ability_Dampeer3_IMPACT_effect:Dampeer_Aura_Heroes				Изменяет схему цели ауры на союзных юнитов.







Ability_Dampeer3_effect_header									







Ability_Dampeer3_tooltip_flavor									Кровавая Мэри для всех!















// State_Dampeer_Ability3_Ally







State_Dampeer_Ability3_Ally_name								Жажда крови







State_Dampeer_Ability3_Ally_description							Атаки имеют вампиризм.







State_Dampeer_Ability3_Ally_FRAME_effect						+{2.5,5,7.5,10}% вампиризм для юнитов дальний тип атаки















// Ability_Dampeer4







Ability_Dampeer4_name											Поглощение







Ability_Dampeer4_name:ult_boost									^gПотребление*^*







Ability_Dampeer4_description									Дампир вонзает зубы в плоть врага, нанося урон и исцеляя себя на величину нанесенного урона.







Ability_Dampeer4_description2									^gЭта способность может быть усилена Посохом Мастера.^*\n\n^gЭффект посоха:^* Максимальное количество сущности увеличивается с 3 до 6, а потеря сущности при смерти изменяется на 3. Продолжительность страха при терроризировании ограничена 2 сек.ами.







Ability_Dampeer4_description2:ult_boost							^gПродолжительность страха при использовании "Терроризировать" ограничена 2 сек.ами.^*







Ability_Dampeer4_description_simple								Нацельтесь на врага, чтобы нанести ему ^o{200,300,400} маг. урона^*, пока Дампир исцеляется от нанесенного урона. Наносит на ^o{30,50,70} больше урона^* за каждую ^rEssence^* Dampeer, которой обладает Дампир, и мгновенно убивает крипов.\n\nДобавляет ^rEssence^* всякий раз, когда используется Consume, или 3 ^rEssences^*, если Consume убивает вражеского героя. Вы можете хранить до ^c3 эссенций^* одновременно. После смерти количество Сущностей уменьшается до минимума 1, если у вас более 1 Сущности.\n\n^gПосох Мастера^* увеличивает лимит Сущностей с 3 до 6 и уменьшает количество эссенций, теряемых после смерти.







Ability_Dampeer4_description_simple:ult_boost					Нацельтесь на врага, чтобы нанести ему ^o{200,300,400} маг. урона^*, пока Дампир исцеляется от нанесенного урона. Наносит на ^o{30,50,70} больше урона^* за каждую ^rEssence^* Dampeer, которой обладает Дампир, и мгновенно убивает крипов.\n\nДобавляет ^rEssence^* всякий раз, когда используется Consume, или 3 ^rEssences^*, если Consume убивает вражеского героя. Вы можете держать до ^g6 эссенций^* одновременно и ^gтерять 3 стопки в случае смерти^*. После смерти количество эссенций уменьшается до минимума 1, если у вас более 1 эссенции.







Ability_Dampeer4_effect_header									







Ability_Dampeer4_effect_header2									







Ability_Dampeer4_tooltip_flavor									Жрать или не жрать? Вот в чем вопрос.







Ability_Dampeer4_IMPACT_effect									Выберите врага, чтобы нанести ему ^o{200,300,400} маг. урона^*, пока Дампир исцеляется от нанесенного урона. Наносит на ^o{30,50,70} больше урона^* за каждую ^rEssence^* Dampeer, которой обладает Дампир, и мгновенно убивает крипов.\n\nДобавляет ^rEssence^* всякий раз, когда используется Consume, или 3 ^rEssences^*, если Consume убивает вражеского героя. Вы можете хранить до ^c3 эссенций^* одновременно. После смерти количество эссенций уменьшается до минимума 1, если у вас более 1 эссенции.







Ability_Dampeer4_IMPACT_effect:ult_boost						Выберите врага, чтобы нанести ему ^o{200,300,400} маг. урона^*, пока Дампир исцеляется от нанесенного урона. Наносит на ^o{30,50,70} больше урона^* за каждую ^rEssence^* Dampeer, которой обладает Дампир, и мгновенно убивает крипов.\n\nДобавляет ^rEssence^* всякий раз, когда используется Consume, или 3 ^rEssences^*, если Consume убивает вражеского героя. Вы можете держать до ^g6 эссенций^* одновременно и ^gтерять 3 стопки в случае смерти^*. После смерти количество эссенций уменьшается до минимума 1, если у вас более 1 эссенции.















// State_Dampeer_Ability4_Hero







State_Dampeer_Ability4_Hero_name								Поглощение







State_Dampeer_Ability4_Hero_FRAME_effect						Смерть усилит Дампира.















// Hero_Dampeer







Hero_Dampeer_name												Дампир







Hero_Dampeer_description										В самые темные дни войны, когда голод бродил по земле, говорят, некоторые люди начали поедать плоть мертвых - а затем и живых. Возможно, таково происхождение Дампира, монстра, питающегося жизненной силой врагов, сеющего ужас перед своими рваными крыльями, чьи штаны - единственное напоминание о человечности.







Hero_Dampeer_role												Dampeer has extremely high survivability and damage output from spells, making him unique amongst item-dependent melee carries. However, his success is highly dependent on the Essence charges he obtains from Consume. 	







































// Ability_Deadlift1







Ability_Deadlift1_name											Нечестивая сила







Ability_Deadlift1_name:ult_boost								^gНечестивая сила*^*







Ability_Deadlift1_description									Deadlift бросает крюк, притягивающий первого вражеского героя или союзника к себе.







Ability_Deadlift1_description2									^gЭта способность может быть усилена Посохом Мастера.^*\n\n^gЭффект посоха:^* уменьшает время восстановления на 1,5 сек. и увеличивает перехват силы до 8.







Ability_Deadlift1_description2:ult_boost                       	\r







Ability_Deadlift1_description_simple							Нацельтесь на область, чтобы нанести ^o{25,50,75,100} маг. урона^* (x2 для юнитов, не являющихся героями) врагам в радиусе, похищая ^o4 силы^* у пойманных вражеских героев на 30 сек.. Максимум 80 бонусной силы.\n\n^gПосох Мастера^* уменьшает время восстановления на 1,5 сек. и увеличивает кражу силы до 8.







Ability_Deadlift1_description_simple:ult_boost					Нацельтесь на область, чтобы нанести ^o{25,50,75,100} маг. урона^* (x2 для юнитов, не являющихся героями) врагам в радиусе действия, похищая ^g8 силы^* у пойманных вражеских героев на 30 сек.. Максимум 80 бонусной силы.







Ability_Deadlift1_IMPACT_effect									Выберите область, чтобы нанести ^o{25,50,75,100} маг. урона^* (x2 для юнитов, не являющихся героями) врагам в радиусе, похищая ^o4 силы^* у пойманных вражеских героев на 30 сек.. Максимум 80 бонусной силы.







Ability_Deadlift1_IMPACT_effect:ult_boost						Выберите область, чтобы нанести ^o{25,50,75,100} маг. урона^* (x2 для юнитов, не являющихся героями) врагам в радиусе действия, похищая ^g8 силы^* у пойманных вражеских героев на 30 сек.. Максимум 80 бонусной силы.







Ability_Deadlift1_tooltip_flavor								Я просто заберу это, раз ты не пользуешься, спасибо.















// State_Deadlift_Ability1_Self







State_Deadlift_Ability1_Self_name								Нечестивая сила















// State_Deadlift_Ability1_Enemy







State_Deadlift_Ability1_Enemy_name								Нечестивая сила















// Ability_Deadlift2







Ability_Deadlift2_name											Натиск







Ability_Deadlift2_description									Deadlift провоцирует вражеского юнита, вынуждая его атаковать Deadlift.







Ability_Deadlift2_description_simple							Нацельтесь на вражеский отряд или постройку, чтобы подбежать к ним, и примените ^o50% замедление скор. движ.^* на 2 сек., вызывая ^o{2,3,4,5} Нежить^* на помощь и заставляя все ближайшие союзные юниты, не являющиеся героями, сделать то же самое.\n\nЗатронутые союзные юниты получают ^o{20,40,60,80} Скор. атаки^* и будут ^o атаковать target^* на 6 сек., нанося увеличенный урон по строениям, но уменьшенный урон другим юнитам.







Ability_Deadlift2_IMPACT_effect									Выберите вражеский отряд или постройку, чтобы бежать к ним со скор. движ. 550 и ходьбой, применяя к цели замедление скор. движ. на 50% и заставляя все ближайшие союзные юниты, не являющиеся героями, делать то же самое.\n\nТакже вызывает {2,3,4,5} Нежить, чтобы помочь вам при использовании. Нежить имеет силу атаки 30 с временем восстановления атаки 1,6 сек..\n\nЗатронутые союзные юниты получают скор. атаки {20,40,60,80} и будут вынуждены атаковать цель в течение 6 сек.. За это время они наносят 150% урона строениям, но наносят 50% урона всем остальным юнитам.







Ability_Deadlift2_tooltip_flavor								Ты потерял рассудок?















// State_Deadlift_Ability2







State_Deadlift_Ability2_name									Натиск







State_Deadlift_Ability2_description								Вынужден атаковать цель















