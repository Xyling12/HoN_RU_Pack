// Ability_ShadowBlade2







Ability_ShadowBlade2_name										Сифон Финта







Ability_ShadowBlade2_description								Shadowblade омрачает врага, усиливая свои следующие атаки.







Ability_ShadowBlade2_description2								







Ability_ShadowBlade2_description_simple 						Нацельтесь на отряд, чтобы прыгнуть на него с расстояния 600 единиц. При контакте с врагом, финт наносит ^o{70,120,170,220} маг. урона^* и ^o поглощает {10,20,30,40}% урона врага, контролируемого игроком, себе в течение 5 сек.^* (0,5x для юнитов NPC).\n\nФорма финта длится 15 сек. или до тех пор, пока не будет вызвана другая форма.\nФорма финта дает ^o{25,30,35,40} Скор. движ. и {4,8,12,16} Ловкость^*.







Ability_ShadowBlade2_effect_header								







Ability_ShadowBlade2_effect_header2								







Ability_ShadowBlade2_tooltip_flavor								Один маленький шаг для человека, один гигантский прыжок для меня.







Ability_ShadowBlade2_IMPACT_effect								Прыгает на целевой отряд, нанося ^o{70,120,170,220} маг. урона^* при ударе и крадет ^o{10,20,30,40}% его урона от атаки^* на 5 сек., если цель является врагом, контролируемым игроком (0,5x для отрядов NPC).\n\n Предоставляет форму финта на 15 сек.. Форма финта дает ^o{4,8,12,16} ловкости и {25,30,35,40} скор. движ.^*. Одновременно может быть активна только одна форма.















